# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real values.

# Runtime: API base URL used in the browser (no trailing slash).
# If omitted, the app derives it from VITE_OPENAPI_SPEC_URL by removing /v3/api-docs.
VITE_API_BASE_URL=https://junhugae.goorm.training/api

# Codegen: OpenAPI spec URL used by Orval (npm run generate)
VITE_OPENAPI_SPEC_URL=https://junhugae.goorm.training/api/v3/api-docs
